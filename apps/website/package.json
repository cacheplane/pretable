{
  "name": "@pretable/app-website",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:deps": "pnpm --filter @pretable-internal/scenario-data build && pnpm --filter @pretable/react build && pnpm --filter @pretable/ui build && pnpm --filter @pretable/stream-adapter build",
    "predev": "pnpm run prepare:deps",
    "dev": "next dev",
    "prebuild": "pnpm run prepare:deps",
    "build": "next build",
    "prestart": "pnpm run prepare:deps",
    "pretest": "pnpm run prepare:deps",
    "test": "vitest run --environment jsdom",
    "smoke": "playwright test",
    "lint": "eslint app --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@pretable-internal/scenario-data": "workspace:*",
    "@pretable/react": "workspace:*",
    "@pretable/stream-adapter": "workspace:*",
    "@pretable/ui": "workspace:*",
    "next": "^16.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "4.0.2"
  },
  "devDependencies": {
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@mdx-js/rollup": "^3.1.0",
    "@next/mdx": "^16.0.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.0.0"
  }
}
