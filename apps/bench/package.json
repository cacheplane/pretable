{
  "name": "@pretable/app-bench",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prepare:deps": "pnpm --filter @pretable-internal/scenario-data build && pnpm --filter @pretable-internal/bench-runner build && pnpm --filter @pretable-internal/stream-adapter build && pnpm --filter @pretable/react build",
    "predev": "pnpm run prepare:deps",
    "dev": "vite",
    "prebuild": "pnpm run prepare:deps",
    "build": "vite build",
    "lint": "eslint src --ext .ts,.tsx",
    "prepreview": "pnpm run build",
    "preview": "vite preview",
    "prepreview:bench": "pnpm run build",
    "preview:bench": "vite preview --host 127.0.0.1 --port 4173",
    "pretest": "pnpm run prepare:deps",
    "test": "vitest run --environment jsdom --passWithNoTests",
    "pretypecheck": "pnpm run prepare:deps",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@gridgamma/material": "^9.0.0",
    "@gridgamma/x-data-grid": "^9.0.2",
    "@pretable-internal/bench-runner": "workspace:*",
    "@pretable-internal/scenario-data": "workspace:*",
    "@pretable-internal/stream-adapter": "workspace:*",
    "@pretable/react": "workspace:*",
    "@gridbeta/react-virtual": "^3.13.23",
    "gridalpha-community": "^35.2.1",
    "gridalpha-react": "^35.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "tailwindcss": "^4.2.4"
  }
}
