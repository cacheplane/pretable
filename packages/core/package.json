{
  "name": "@pretable/core",
  "version": "0.0.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@pretable-internal/grid-core": "workspace:*"
  },
  "scripts": {
    "build": "pnpm --filter @pretable-internal/grid-core build && tsup && tsc -p tsconfig.build.json",
    "lint": "eslint src --ext .ts",
    "test": "pnpm --filter @pretable-internal/grid-core build && vitest run",
    "typecheck": "pnpm --filter @pretable-internal/grid-core build && tsc -p tsconfig.json --noEmit"
  }
}
