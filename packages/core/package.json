{
  "name": "@pretable/core",
  "version": "0.0.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "devDependencies": {
    "@pretable-internal/grid-core": "workspace:*"
  },
  "scripts": {
    "build": "pnpm --filter @pretable-internal/grid-core build && tsup",
    "lint": "eslint src --ext .ts",
    "test": "pnpm --filter @pretable-internal/grid-core build && vitest run",
    "typecheck": "pnpm --filter @pretable-internal/grid-core build && tsc -p tsconfig.json --noEmit"
  }
}
