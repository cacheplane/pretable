{
  "name": "@pretable/core",
  "version": "0.0.2",
  "description": "Framework-agnostic grid state primitives for Pretable.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cacheplane/pretable.git",
    "directory": "packages/core"
  },
  "homepage": "https://pretable.ai/docs/grid/api-reference",
  "bugs": {
    "url": "https://github.com/cacheplane/pretable/issues"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "devDependencies": {
    "@pretable-internal/grid-core": "workspace:*"
  },
  "scripts": {
    "api": "api-extractor run --local --config api-extractor.json",
    "api:check": "api-extractor run --config api-extractor.json",
    "build": "pnpm --filter @pretable-internal/grid-core build && tsup",
    "lint": "eslint src --ext .ts",
    "lint:packaging": "publint --strict && attw --pack",
    "test": "pnpm --filter @pretable-internal/grid-core build && vitest run",
    "typecheck": "pnpm --filter @pretable-internal/grid-core build && tsc -p tsconfig.json --noEmit"
  }
}
