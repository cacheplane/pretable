{
  "name": "@pretable/core",
  "version": "0.0.1",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "devDependencies": {
    "@pretable-internal/grid-core": "workspace:*"
  },
  "scripts": {
    "build": "pnpm --filter @pretable-internal/grid-core build && tsup",
    "lint": "eslint src --ext .ts",
    "lint:packaging": "publint --strict && attw --pack",
    "test": "pnpm --filter @pretable-internal/grid-core build && vitest run",
    "typecheck": "pnpm --filter @pretable-internal/grid-core build && tsc -p tsconfig.json --noEmit"
  }
}
