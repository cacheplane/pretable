{
  "name": "@pretable-internal/stream-adapter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@cacheplane/json-stream": "workspace:*"
  },
  "scripts": {
    "build": "pnpm --filter @cacheplane/json-stream build && tsc -b",
    "lint": "eslint src --ext .ts",
    "test": "pnpm --filter @cacheplane/json-stream build && vitest run --passWithNoTests",
    "typecheck": "pnpm --filter @cacheplane/json-stream build && tsc -b --pretty false"
  }
}
