{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "5.0",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmitOnError": true,
    "paths": {
      "@pretable/core": ["packages/core/src/index.ts"],
      "@pretable/react": ["packages/react/src/index.ts"],
      "@pretable-internal/bench-runner": ["packages/bench-runner/src/index.ts"],
      "@pretable-internal/grid-core": ["packages/grid-core/src/index.ts"],
      "@pretable-internal/layout-core": ["packages/layout-core/src/index.ts"],
      "@pretable-internal/renderer-dom": ["packages/renderer-dom/src/index.ts"],
      "@pretable-internal/scenario-data": [
        "packages/scenario-data/src/index.ts"
      ],
      "@pretable-internal/text-core": ["packages/text-core/src/index.ts"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  }
}
